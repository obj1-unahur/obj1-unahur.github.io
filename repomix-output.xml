<file path="src/layouts/PostCursadaLayout.astro">
---
import { Breadcrumbs } from 'accessible-astro-components'
import { BreadcrumbsItem } from 'accessible-astro-components'
import { PATH, PATH_CURSADA } from '@/paths.js'
import LayoutSemanas from './LayoutSemanas.astro'
import VideosDeSemana from '@components/VideosDeSemana.astro'
import ActividadesDeSemana from '@components/ActividadesDeSemana.astro'
import HorariosDeSemana from '@components/HorariosDeSemana.astro'
import CardSecciones from '@/components/CardSecciones.astro'

const { frontmatter } = Astro.props

const { title, videos, horarios, ejercicios, atencion, importante } =
	frontmatter
---

<LayoutSemanas title={title}>
	<div class="container">
		<div class="mt-12">
			<Breadcrumbs>
				<BreadcrumbsItem
					href={PATH}
					label="Inicio"
				/>
				<BreadcrumbsItem
					href={PATH_CURSADA}
					label="Cursada"
				/>
				<BreadcrumbsItem
					currentPage={true}
					label={title}
				/>
			</Breadcrumbs>
		</div>
	</div>

	<div class="container">
		<div class="my-12">
			<h1 class="pb-3">{title}</h1>

			{
				atencion ? (
					<CardSecciones
						title="Atención"
						atencion>
						{atencion}
					</CardSecciones>
				) : null
			}

			{
				importante ? (
					<CardSecciones
						title="Importante"
						importante>
						{importante}
					</CardSecciones>
				) : null
			}

			<div class="pb-2">
				<slot />
			</div>

			{horarios ? <HorariosDeSemana horarios={horarios} /> : null}

			{
				videos && (
					<VideosDeSemana
						titulo="Videos"
						videos={videos}
					/>
				)
			}

			<ActividadesDeSemana ejercicios={ejercicios} />
		</div>
	</div>
</LayoutSemanas>

<script>
	if (!window.__githubHandlerAttached) {
		window.__githubHandlerAttached = true

		// ---------- textos ----------
		const PROCESSING_TEXT = 'Procesando...'
		const SUCCESS_TEXT = '✓ ¡Listo! Abriendo...'
		const ERROR_TEXT = '✗ Error, intentá de nuevo'
		const ACCEPTED_TEXT = 'Aceptado. Ir al repo →'

		// ---------- utilidades ----------
		const getInput = () => document.querySelector('.github-user-input')

		const syncInput = () => {
			const input = getInput()
			const saved = localStorage.getItem('githubUser')
			if (input && saved && input.value !== saved) {
				input.value = saved
			}
		}

		// ---------- manejo de ejercicios aceptados ----------
		const ACCEPTED_KEY = 'acceptedAssignments'
		const getAcceptedAssignments = () => {
			try {
				return JSON.parse(localStorage.getItem(ACCEPTED_KEY)) || []
			} catch {
				return []
			}
		}
		const markAssignmentAccepted = (prefix, type) => {
			const accepted = getAcceptedAssignments()
			if (!accepted.some((a) => a.prefix === prefix && a.type === type)) {
				accepted.push({ prefix, type })
				localStorage.setItem(ACCEPTED_KEY, JSON.stringify(accepted))
			}
		}
		const isAssignmentAccepted = (prefix, type) =>
			getAcceptedAssignments().some(
				(a) => a.prefix === prefix && a.type === type
			)

		const CHECK_ICON_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`

		const TEAM_ICON_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`

		const updateAcceptedButtons = () => {
			document.querySelectorAll('.aceptar-invitacion').forEach((btn) => {
				const prefix = btn.getAttribute('data-prefix')
				const type = btn.getAttribute('data-type') ?? 'individual'
				if (isAssignmentAccepted(prefix, type)) {
					btn.innerHTML = `${CHECK_ICON_SVG} ${ACCEPTED_TEXT}`
				}
			})
		}

		document.addEventListener('DOMContentLoaded', updateAcceptedButtons)
		document.addEventListener('astro:page-load', updateAcceptedButtons)
		updateAcceptedButtons()

		// ---------- sincronización del input ----------
		document.addEventListener('DOMContentLoaded', syncInput)
		document.addEventListener('astro:page-load', syncInput)
		syncInput()

		document.addEventListener('input', (e) => {
			if (e.target.classList.contains('github-user-input')) {
				localStorage.setItem('githubUser', e.target.value.trim())
			}
		})

		// ---------- Modal ----------
		const createTeamModal = () => {
			const existing = document.getElementById('team-modal')
			if (existing) existing.remove()

			const style =
				document.getElementById('team-modal-styles') ||
				document.createElement('style')
			if (!style.id) {
				style.id = 'team-modal-styles'
				style.textContent = `
          #team-modal {
            --tm-accent:        var(--action-color, #40bf6a);
            --tm-accent-hover:  var(--action-color-state, #17823b);
            --tm-bg:            var(--background, #fff);
            --tm-bg-input:      var(--neutral-background, #fafafa);
            --tm-border:        var(--neutral-400, #e6e6e6);
            --tm-text:          var(--font-color, #1a1a1a);
            --tm-text-muted:    var(--neutral-700, #595959);
            --tm-radius:        var(--radius-large, 6px);
            --tm-font:          var(--font-family-default, "Open Sans", sans-serif);
          }

          .team-modal-backdrop {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.45);
            backdrop-filter: blur(3px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.25s ease, visibility 0.25s ease;
          }
          .team-modal-backdrop.open {
            opacity: 1;
            visibility: visible;
          }

          .team-modal {
            font-family: var(--tm-font);
            background: var(--tm-bg);
            color: var(--tm-text);
            border: 3px solid var(--tm-accent);
            border-radius: var(--tm-radius);
            padding: 1.5rem;
            max-width: 380px;
            width: 90%;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
            transform: translateY(6px);
            transition: transform 0.2s ease;
          }
          .team-modal-backdrop.open .team-modal {
            transform: translateY(0);
          }

          .team-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--tm-border);
          }
          .team-modal-header h3 {
            font-family: var(--tm-font);
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0;
            color: var(--tm-text);
          }

          .team-close-btn {
            background: none;
            border: none;
            font-size: 1.5rem;
            line-height: 1;
            cursor: pointer;
            color: var(--tm-text-muted);
            padding: 0.15rem 0.4rem;
            border-radius: var(--tm-radius);
            transition: color 0.15s ease, background-color 0.15s ease;
          }
          .team-close-btn:hover {
            color: var(--tm-text);
            background-color: var(--tm-border);
          }

          .team-action-btn {
            font-family: var(--tm-font);
            font-size: 1rem;
            font-weight: 700;
            width: 100%;
            padding: 0.75rem 1rem;
            border: 3px solid var(--tm-accent);
            border-radius: var(--tm-radius);
            background-color: var(--tm-accent);
            color: var(--neutral-900, #1a1a1a);
            cursor: pointer;
            text-align: center;
            transition: background-color 0.15s ease, border-color 0.15s ease;
            line-height: 1;
          }
          .team-action-btn:hover:not(:disabled) {
            background-color: var(--tm-accent-hover);
            border-color: var(--tm-accent-hover);
          }
          .team-action-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
          }

          .combobox {
            position: relative;
            display: flex;
            flex-direction: column;
          }

          .combobox-input {
            font-family: var(--tm-font);
            font-size: 0.95rem;
            width: 100%;
            padding: 0.65rem 0.85rem;
            background: var(--tm-bg-input);
            color: var(--tm-text);
            border: 2px solid var(--tm-border);
            border-radius: var(--tm-radius);
            outline: none;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
          }
          .combobox-input:focus {
            border-color: var(--tm-accent);
            box-shadow: 0 0 0 2px color-mix(in srgb, var(--tm-accent) 25%, transparent);
          }
          .combobox-input::placeholder {
            color: var(--tm-text-muted);
          }

          .combobox-list {
            display: none;
            position: absolute;
            top: calc(100% + 3px);
            left: 0; right: 0;
            max-height: 170px;
            overflow-y: auto;
            background: var(--tm-bg);
            border: 2px solid var(--tm-accent);
            border-radius: var(--tm-radius);
            z-index: 10;
            list-style: none;
            padding: 0.25rem;
            margin: 0;
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
          }
          .combobox-list.open { display: block; }

          .combobox-option {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.55rem 0.75rem;
            font-size: 0.9rem;
            font-family: var(--tm-font);
            color: var(--tm-text);
            cursor: pointer;
            border-radius: calc(var(--tm-radius) - 2px);
            transition: background-color 0.12s ease, color 0.12s ease;
          }
          .combobox-option .team-icon {
            flex-shrink: 0;
            opacity: 0.5;
            transition: opacity 0.12s ease;
          }
          .combobox-option .team-icon svg {
            display: block;
          }
          .combobox-option:hover,
          .combobox-option.active {
            background-color: var(--tm-accent);
            color: var(--neutral-900, #1a1a1a);
          }
          .combobox-option:hover .team-icon,
          .combobox-option.active .team-icon {
            opacity: 1;
          }

          .team-modal-hint {
            font-family: var(--tm-font);
            font-size: 0.75rem;
            color: var(--tm-text-muted);
            text-align: center;
            margin-top: -0.25rem;
          }

          @media (max-width: 400px) {
            .team-modal { padding: 1.1rem; gap: 0.75rem; }
          }
        `
				document.head.appendChild(style)
			}

			const backdrop = document.createElement('div')
			backdrop.className = 'team-modal-backdrop'
			backdrop.id = 'team-modal'
			backdrop.innerHTML = `
        <div class="team-modal" role="dialog" aria-modal="true" aria-labelledby="team-modal-title">
          <div class="team-modal-header">
            <h3 id="team-modal-title">Elegi o crea tu equipo</h3>
            <button class="team-close-btn" aria-label="Cerrar">&times;</button>
          </div>
          <button class="team-action-btn" id="team-action-btn" disabled>Escribi un nombre</button>
          <div class="combobox">
            <input
              type="text"
              placeholder="Busca o escribi el nombre del equipo..."
              class="combobox-input"
              id="combobox-input"
              autocomplete="off"
              aria-label="Nombre del equipo"
            >
            <ul class="combobox-list" id="combobox-list" role="listbox"></ul>
          </div>
          <p class="team-modal-hint">Usa las flechas para navegar, Enter para confirmar</p>
        </div>
      `
			document.body.appendChild(backdrop)
			return backdrop
		}

		const openTeamModal = (teams) => {
			return new Promise((resolve, reject) => {
				const modal = createTeamModal()
				const backdrop = modal
				const input = modal.querySelector('#combobox-input')
				const list = modal.querySelector('#combobox-list')
				const actionBtn = modal.querySelector('#team-action-btn')
				const closeBtn = modal.querySelector('.team-close-btn')

				let activeIndex = -1
				let currentSuggestions = []
				let resolved = false
				let isNavigating = false // Flag para saber si el usuario navega con flechas

				const updateUI = (scrollToActive = false) => {
					const search = input.value.trim().toLowerCase()
					currentSuggestions = search
						? teams.filter((t) => t.teamName.toLowerCase().includes(search))
						: []

					// Si el activeIndex actual ya no es valido para las nuevas sugerencias, resetear
					if (activeIndex >= currentSuggestions.length) {
						activeIndex = -1
						isNavigating = false
					}

					list.innerHTML = ''
					currentSuggestions.forEach((team, idx) => {
						const li = document.createElement('li')
						li.className = 'combobox-option'
						li.setAttribute('role', 'option')
						li.innerHTML = `<span class="team-icon">${TEAM_ICON_SVG}</span><span>${team.teamName}</span>`
						li.addEventListener('click', () => {
							input.value = team.teamName
							activeIndex = idx
							isNavigating = false
							updateUI()
							input.focus()
						})
						if (idx === activeIndex) li.classList.add('active')
						list.appendChild(li)
					})

					if (currentSuggestions.length > 0 && search) {
						list.classList.add('open')
					} else {
						list.classList.remove('open')
					}

					const exactMatch = teams.some(
						(t) => t.teamName.toLowerCase() === search
					)
					const validSearch = search !== ''

					if (exactMatch) {
						actionBtn.textContent = 'Unirse al equipo'
						actionBtn.disabled = false
					} else if (validSearch) {
						actionBtn.textContent = `Crear "${input.value.trim()}"`
						actionBtn.disabled = false
					} else {
						actionBtn.textContent = 'Escribi un nombre'
						actionBtn.disabled = true
					}

					// Solo auto-seleccionar el exactMatch si NO esta navegando con flechas
					if (exactMatch && !isNavigating) {
						const matchIndex = currentSuggestions.findIndex(
							(t) => t.teamName.toLowerCase() === search
						)
						if (matchIndex >= 0) {
							activeIndex = matchIndex
							list.querySelectorAll('.combobox-option').forEach((el, i) => {
								el.classList.toggle('active', i === activeIndex)
							})
						}
					}

					// Scroll hacia el elemento activo
					if (scrollToActive && activeIndex >= 0) {
						const activeEl =
							list.querySelectorAll('.combobox-option')[activeIndex]
						if (activeEl) {
							activeEl.scrollIntoView({ block: 'nearest', behavior: 'smooth' })
						}
					}
				}

				const cleanup = () => {
					if (resolved) return
					resolved = true
					backdrop.classList.remove('open')
					document.removeEventListener('keydown', escHandler)
					document.removeEventListener('click', outsideClickHandler)
				}

				const closeModal = () => {
					cleanup()
					reject(new Error('Cancelado por el usuario'))
				}

				const handleAction = () => {
					if (resolved) return
					const selected = input.value.trim()
					if (!selected) return
					const exists = teams.some(
						(t) => t.teamName.toLowerCase() === selected.toLowerCase()
					)
					cleanup()
					if (exists) {
						resolve({ teamName: selected, mode: 'join' })
					} else {
						resolve({ teamName: selected, mode: 'create' })
					}
				}

				input.addEventListener('input', () => {
					activeIndex = -1
					isNavigating = false
					updateUI()
				})

				input.addEventListener('focus', () => {
					if (input.value.trim()) updateUI()
				})

				input.addEventListener('keydown', (e) => {
					if (e.key === 'Escape') {
						closeModal()
						return
					}

					const items = list.querySelectorAll('.combobox-option')
					if (e.key === 'ArrowDown') {
						e.preventDefault()
						if (items.length > 0) {
							isNavigating = true
							activeIndex = Math.min(activeIndex + 1, items.length - 1)
							updateUI(true)
						}
					} else if (e.key === 'ArrowUp') {
						e.preventDefault()
						if (items.length > 0) {
							isNavigating = true
							activeIndex = Math.max(activeIndex - 1, 0)
							updateUI(true)
						}
					} else if (e.key === 'Enter') {
						e.preventDefault()
						if (activeIndex >= 0 && activeIndex < items.length) {
							items[activeIndex].click()
						} else if (!actionBtn.disabled) {
							handleAction()
						}
					}
				})

				const outsideClickHandler = (e) => {
					if (!backdrop.contains(e.target)) {
						list.classList.remove('open')
					}
				}
				document.addEventListener('click', outsideClickHandler)

				actionBtn.addEventListener('click', handleAction)
				closeBtn.addEventListener('click', closeModal)

				const escHandler = (e) => {
					if (e.key === 'Escape') closeModal()
				}
				document.addEventListener('keydown', escHandler)

				backdrop.classList.add('open')
				setTimeout(() => input.focus(), 100)
			})
		}

		// ---------- click en botón aceptar asignación ----------
		document.addEventListener('click', async (e) => {
			const btn = e.target.closest('.aceptar-invitacion')
			if (!btn) return
			e.preventDefault()

			const input = getInput()
			let usuario = input?.value?.trim() || localStorage.getItem('githubUser')
			if (!usuario) {
				alert('Ingresa tu usuario de GitHub en la seccion de ejercicios')
				return
			}
			localStorage.setItem('githubUser', usuario)

			const originalHTML = btn.innerHTML
			btn.disabled = true
			btn.textContent = PROCESSING_TEXT

			const type = btn.getAttribute('data-type') ?? 'individual'
			const prefix = btn.getAttribute('data-prefix')

			const restoreButton = (targetBtn) => {
				targetBtn.disabled = false
				targetBtn.innerHTML = originalHTML
			}

			// INDIVIDUAL
			if (type === 'individual') {
				try {
					const res = await fetch(
						'https://worker-objetos.objetos-unahur.workers.dev',
						{
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								type: 'individual',
								template: btn.getAttribute('data-template'),
								templateOrg: btn.getAttribute('data-template-org'),
								destOrg: btn.getAttribute('data-dest-org'),
								prefix,
								isPrivate: btn.getAttribute('data-private') === 'true',
								username: usuario,
							}),
						}
					)
					const data = await res.json()
					if (data.status === 'ok') {
						markAssignmentAccepted(prefix, type)
						btn.textContent = SUCCESS_TEXT
						setTimeout(() => {
							window.open(`${data.repoUrl}/invitations`, '_blank')
							updateAcceptedButtons()
							btn.disabled = false
						}, 1500)
					} else {
						throw new Error(data.error || 'Error al procesar')
					}
				} catch (err) {
					btn.textContent = ERROR_TEXT
					btn.disabled = false
					console.error(err)
					setTimeout(() => {
						btn.innerHTML = originalHTML
					}, 2000)
				}
				return
			}

			// GRUPAL
			const destOrg = btn.getAttribute('data-dest-org')
			if (!destOrg || destOrg === 'undefined') {
				alert('Error: falta la organizacion de destino en el boton.')
				restoreButton(btn)
				return
			}
			const cacheKey = `teamCache_${destOrg}`

			try {
				let teamName, mode

				if (e.shiftKey) {
					localStorage.removeItem(cacheKey)
				}

				const cachedTeam = localStorage.getItem(cacheKey)

				if (cachedTeam) {
					const parsed = JSON.parse(cachedTeam)
					teamName = parsed.teamName
					mode = parsed.mode
				} else {
					btn.textContent = 'Buscando equipos...'

					let teams = []
					try {
						const listRes = await fetch(
							'https://worker-objetos.objetos-unahur.workers.dev',
							{
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify({
									type: 'group',
									action: 'list-teams',
									destOrg,
								}),
							}
						)
						const listData = await listRes.json()
						if (listData.error) throw new Error(listData.error)
						teams = listData.teams || []
					} catch (fetchErr) {
						console.error('Error al buscar equipos:', fetchErr)
						btn.textContent = ERROR_TEXT
						setTimeout(() => {
							restoreButton(btn)
						}, 2000)
						return
					}

					let decision
					try {
						decision = await openTeamModal(teams)
					} catch (cancelErr) {
						restoreButton(btn)
						return
					}

					teamName = decision.teamName
					mode = decision.mode
					localStorage.setItem(cacheKey, JSON.stringify({ teamName, mode }))
				}

				const activeBtn =
					document.querySelector(
						`.aceptar-invitacion[data-prefix="${prefix}"]`
					) || btn
				activeBtn.disabled = true
				activeBtn.textContent = PROCESSING_TEXT

				const acceptRes = await fetch(
					'https://worker-objetos.objetos-unahur.workers.dev',
					{
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							type: 'group',
							action: 'accept',
							username: usuario,
							prefix,
							destOrg,
							templateOrg: btn.getAttribute('data-template-org'),
							templateRepo: btn.getAttribute('data-template'),
							isPrivate: btn.getAttribute('data-private') === 'true',
							mode,
							teamName,
						}),
					}
				)
				const acceptData = await acceptRes.json()

				if (acceptData.success) {
					markAssignmentAccepted(prefix, type)
					activeBtn.textContent = SUCCESS_TEXT
					setTimeout(() => {
						window.open(acceptData.repoUrl, '_blank')
						updateAcceptedButtons()
						activeBtn.disabled = false
					}, 1500)
				} else {
					if (acceptData.error?.includes('no existe')) {
						localStorage.removeItem(cacheKey)
					}
					throw new Error(acceptData.error || 'Error al procesar')
				}
			} catch (err) {
				const currentBtn =
					document.querySelector(
						`.aceptar-invitacion[data-prefix="${prefix}"]`
					) || btn
				currentBtn.textContent = ERROR_TEXT
				currentBtn.disabled = false
				console.error(err)
				setTimeout(() => {
					currentBtn.innerHTML = originalHTML
				}, 2000)
			}
		})
	}
</script>
