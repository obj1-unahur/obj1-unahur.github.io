<file path="src/components/CardEjercicio.astro">
---
import { Icon } from 'astro-icon/components'

// ── Props con valores por defecto e inferidos ────────────────────
let {
	title,
	comentarios,
	ejemploUrl,
	urlTemplate, // obligatorio: https://github.com/org/repo
	destOrg = urlTemplate?.split('/')[3] ?? '',
	prefix = urlTemplate?.split('/').pop()?.split('?')[0] ?? '',
	isPrivate = false,
	type = 'individual',
	obligatorio,
	consultas,
} = Astro.props

// ── Si es obligatorio y no se especificó isPrivate, forzar a true ──
if (obligatorio && Astro.props.isPrivate === undefined) {
	isPrivate = true
}

// ── Derivados para worker y consigna ────────────────────────────
const partes = urlTemplate
	? urlTemplate.replace('https://github.com/', '').split('/')
	: []
const templateOrg = partes[0] ?? ''
const template = (partes[1] ?? '').split('?')[0] ?? ''
const repoUrl = urlTemplate
	? urlTemplate.replace('https://github.com/', '')
	: ''
const defaultBranch = Astro.props.defaultBranch ?? 'main'
---

<div class="feature m-3">
	<div class="flex h-full w-full flex-col">
		<!-- Etiqueta de obligatorio (si corresponde) -->
		{
			obligatorio && (
				<div class="obligatorio-container">
					<span class="text-obligatorio">Esta actividad es obligatoria</span>
					<Icon
						class="icon-obligatorio"
						name="ion:alert-outline"
					/>
				</div>
			)
		}
		<!-- Etiqueta de consultas (si corresponde) -->
		{
			consultas && (
				<div class="obligatorio-container">
					<span class="text-obligatorio">Ejercicio de clase de consultas</span>
					<svg
						class="icon-svg"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24">
						<mask
							id="lineMdGithubLoop0"
							width="24"
							height="24"
							x="0"
							y="0">
							<g fill="#fff">
								<ellipse
									cx="9.5"
									cy="9"
									rx="1.5"
									ry="1"
								/>
								<ellipse
									cx="14.5"
									cy="9"
									rx="1.5"
									ry="1"
								/>
							</g>
						</mask>
						<g
							fill="none"
							stroke="currentColor"
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="3">
							<path
								stroke-dasharray="32"
								stroke-dashoffset="32"
								d="M12 4c1.67 0 2.61 0.4 3 0.5c0.53 -0.43 1.94 -1.5 3.5 -1.5c0.34 1 0.29 2.22 0 3c0.75 1 1 2 1 3.5c0 2.19 -0.48 3.58 -1.5 4.5c-1.02 0.92 -2.11 1.37 -3.5 1.5c0.65 0.54 0.5 1.87 0.5 2.5c0 0.73 0 3 0 3M12 4c-1.67 0 -2.61 0.4 -3 0.5c-0.53 -0.43 -1.94 -1.5 -3.5 -1.5c-0.34 1 -0.29 2.22 0 3c-0.75 1 -1 2 -1 3.5c0 2.19 0.48 3.58 1.5 4.5c1.02 0.92 2.11 1.37 3.5 1.5c-0.65 0.54 -0.5 1.87 -0.5 2.5c0 0.73 0 3 0 3">
								<animate
									fill="freeze"
									attributeName="stroke-dashoffset"
									dur="0.105s"
									values="32;0"
								/>
							</path>
							<path
								stroke-dasharray="10"
								stroke-dashoffset="10"
								d="M9 19c-1.406 0-2.844-.563-3.688-1.188C4.47 17.188 4.22 16.157 3 15.5">
								<animate
									attributeName="d"
									dur="0.45s"
									repeatCount="indefinite"
									values="M9 19c-1.406 0-2.844-.563-3.688-1.188C4.47 17.188 4.22 16.157 3 15.5;M9 19c-1.406 0-3-.5-4-.5-.532 0-1 0-2-.5;M9 19c-1.406 0-2.844-.563-3.688-1.188C4.47 17.188 4.22 16.157 3 15.5"
								/>
								<animate
									fill="freeze"
									attributeName="stroke-dashoffset"
									begin="0.12s"
									dur="0.03s"
									values="10;0"
								/>
							</path>
						</g>
						<rect
							width="8"
							height="4"
							x="8"
							y="11"
							fill="currentColor"
							mask="url(#lineMdGithubLoop0)">
							<animate
								attributeName="y"
								dur="1.5s"
								keyTimes="0;0.45;0.46;0.54;0.55;1"
								repeatCount="indefinite"
								values="11;11;7;7;11;11"
							/>
						</rect>
					</svg>
				</div>
			)
		}

		<h3 class="p-2 text-xl">{title}</h3>

		<!-- Comentarios -->
		{
			comentarios && comentarios.length > 0 && (
				<ul>
					{comentarios.map(({ name }) => (
						<li>{name}</li>
					))}
				</ul>
			)
		}

		<!-- Fecha de entrega -->
		{
			Astro.props.fechaDeEntrega && (
				<p class="p-2 text-lg font-bold">
					Fecha de entrega:{' '}
					<span class="font-thin">{Astro.props.fechaDeEntrega}</span>
				</p>
			)
		}

		<!-- Ejemplo -->
		{
			ejemploUrl && (
				<a
					class="has-icon button preview-button"
					href={ejemploUrl}
					target="_blank">
					<Icon name="ion:arrow-up-right-box-outline" />
					Ver el Ejemplo
				</a>
			)
		}

		<!-- Botón de aceptar asignación (el worker se maneja desde PostCursadaLayout.astro) -->
		{
			urlTemplate && (
				<button
					type="button"
					data-template={template}
					data-template-org={templateOrg}
					data-dest-org={destOrg}
					data-prefix={prefix}
					data-private={isPrivate ? 'true' : 'false'}
					data-type={type}
					class="aceptar-invitacion has-icon button preview-button">
					<Icon name="ion:logo-github" />
					Aceptar la asignación
				</button>
			)
		}

		<!-- Consigna -->
		<a
			href={`https://github.com/${repoUrl}/blob/${defaultBranch}/README.md`}
			target="_blank"
			class="has-icon button preview-button">
			<Icon name="ion:eye" />
			Consigna
		</a>
	</div>
</div>

<style lang="scss">
