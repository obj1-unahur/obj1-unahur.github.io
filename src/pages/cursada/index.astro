---
import CardSemana from '@components/CardSemana.astro'
import DefaultLayout from '@layouts/DefaultLayout.astro'

const semanas = await Astro.glob('./*.md') //Para buscar todos los archivos .md en la carpeta
---

<DefaultLayout
	title="Cursada - Objetos I"
	description="Universidad Nacional de Hurlingham, cursada / semana de Programación con Objetos I"
	author="Objetos I">
	<section class="my-12">
		<div class="space-content container">
			<h1>Cursada Actual</h1>
			<ul class="m-auto">
				{
					semanas
						.reverse()
						.filter((semana) => {
							if (!semana.frontmatter.inicio) return true
							const inicio = new Date(semana.frontmatter.inicio)
							// Astro parsea las fechas en UTC, compensamos UTC-3 de Argentina
							inicio.setHours(inicio.getHours() + 3)
							return new Date() >= inicio
						})
						.map((semana) => (
							<li>
								<CardSemana
									frontmatter={semana.frontmatter}
									url={semana.url}
								/>
							</li>
						))
				}
			</ul>
		</div>
	</section>
</DefaultLayout>

<style lang="scss">
	ul {
		display: grid;
		grid-template-columns: 1fr;
		grid-gap: 4rem;

		@media (min-width: 550px) {
			grid-template-columns: repeat(2, 1fr);
			grid-gap: 2rem;
		}

		@media (min-width: 950px) {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
