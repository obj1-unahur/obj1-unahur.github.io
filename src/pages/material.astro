---
import AsideMenu from '@/components/AsideMenu.astro'
import CardSecciones from '@/components/CardSecciones.astro'
import SeccionListaCopyCode from '@/components/SeccionListaCopyCode.astro'
import Separador from '@/components/Separador.astro'
import TablaDeActividades from '@/components/TablaDeActividades.astro'
import DefaultLayout from '@/layouts/DefaultLayout.astro'
import Wollok from '../content/Wollok.json'
import Git from '../content/Git.json'
import Ejercicios from '../content/Ejercicios.json'

const elementosComunes = await Astro.glob(
	'../content/sintaxis_basica_wollok.md'
)

const {
	sintaxisBasica,
	operadoresLogicosYMatematicos,
	opSimplesCollList,
	opAvanCollList,
	mensajeDeColl,
	comandosBasicGit,
} = elementosComunes[0].frontmatter
---

<DefaultLayout title="Material - Objetos I">
	<div class="flex">
		<aside
			class="sticky left-0 top-0 h-screen w-max min-w-52 overflow-y-auto rounded-lg bg-gradient-to-t from-slate-200 to-[--background] dark:from-zinc-800 dark:to-[--background]">
			<AsideMenu
				title="Wollok"
				data={Wollok}
			/>
			<AsideMenu
				title="Git"
				data={Git}
			/>
			<AsideMenu
				title="Ejercicios"
				data={Ejercicios}
			/>
		</aside>

		<section class="m-auto md:mx-4">
			<h3 class="mb-10 text-center text-3xl sm:text-5xl">Material</h3>

			<CardSecciones title="Wollok">
				<SeccionListaCopyCode
					id="SintaxisBasica"
					title="Sintaxis basica"
					lista={sintaxisBasica}
				/>
				<SeccionListaCopyCode
					id="OpLogicos"
					title="Operadores lógicos"
					lista={operadoresLogicosYMatematicos}
				/>
				<SeccionListaCopyCode
					id="OpSimples"
					title="Operaciones simples"
					lista={opSimplesCollList}
				/>
				<SeccionListaCopyCode
					id="OpAvanzadas"
					title="Operaciones avanzadas"
					lista={opAvanCollList}
				/>
				<SeccionListaCopyCode
					id="msgColecciones"
					title="Mensajes de colecciones"
					lista={mensajeDeColl}
				/>
			</CardSecciones>

			<CardSecciones title="Git">
				<SeccionListaCopyCode
					id="ComandosBasicos"
					title="Comandos basicos de Git"
					lista={comandosBasicGit}
				/>

				<Separador />

				<article id="git-links">
					<p id="git-introduccion">Introducción a Git y Github.</p>
					<a
						href="https://docs.google.com/presentation/d/1laFLpZzUnR9PSwb2U0xDdHJDvQ97pQBrJCU-vsV4bxQ/edit?usp=sharing"
						target="_blank"
						class="btn-recurso">
						Ver recurso →
					</a>

					<p id="git-guia">Guía rápida de cómo usar Git.</p>
					<a
						href="https://github.com/obj1-unahur-2018s2/docs/wiki/Guia-r%C3%A1pida-de-GIT"
						target="_blank"
						class="btn-recurso">
						Ver recurso →
					</a>

					<p id="git-apunte">Otro apunte de Git.</p>
					<a
						href="https://docs.google.com/document/d/1ozqfYCwt-37stynmgAd5wJlNOFKWYQeIZoeqXpAEs0I/edit"
						target="_blank"
						class="btn-recurso">
						Ver recurso →
					</a>

					<p id="git-tutorial">Tutorial interactivo de Git.</p>
					<a
						href="https://github.com/jlord/git-it-electron"
						target="_blank"
						class="btn-recurso">
						Ver recurso →
					</a>

					<p id="git-machete">Machete de comandos de Git.</p>
					<a
						href="/pdf/ComandosBasicosDeGit.pdf"
						target="_blank"
						class="btn-recurso">
						Ver recurso →
					</a>
				</article>
			</CardSecciones>

			<CardSecciones
				id="guia"
				title="Guías de ejercicios adicionales">
				<TablaDeActividades />
			</CardSecciones>
		</section>
	</div>
</DefaultLayout>

<style lang="scss">
	html {
		scroll-behavior: smooth;
	}

	#git-links {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1.5fr 0.3fr;
		grid-template-areas:
			'intro link1'
			'guia link2'
			'apunte link3'
			'tutorial link4'
			'machete link5';
	}

	#git-introduccion {
		grid-area: intro;
	}
	#git-guia {
		grid-area: guia;
	}
	#git-apunte {
		grid-area: apunte;
	}
	#git-tutorial {
		grid-area: tutorial;
	}
	#git-machete {
		grid-area: machete;
	}

	#git-links a:nth-of-type(1) {
		grid-area: link1;
	}
	#git-links a:nth-of-type(2) {
		grid-area: link2;
	}
	#git-links a:nth-of-type(3) {
		grid-area: link3;
	}
	#git-links a:nth-of-type(4) {
		grid-area: link4;
	}
	#git-links a:nth-of-type(5) {
		grid-area: link5;
	}

	/* 🎨 BOTÓN CON BUEN CONTRASTE */
	.btn-recurso {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		background-color: #e2e8f0; /* gris claro */
		color: #0f172a; /* texto oscuro fuerte */
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.btn-recurso:hover {
		background-color: #cbd5f5; /* más contraste */
		color: #020617;
		transform: scale(1.03);
	}

	/* 🌙 DARK MODE */
	.dark .btn-recurso {
		background-color: #27272a;
		color: #f4f4f5;
	}

	.dark .btn-recurso:hover {
		background-color: #3f3f46;
		color: #ffffff;
	}

	@media (max-width: 775px) {
		aside {
			display: none;
		}
	}
</style>
