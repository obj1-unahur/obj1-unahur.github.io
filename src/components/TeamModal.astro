---
// src/components/TeamModal.astro
---

<div
	id="team-modal"
	class="team-modal-backdrop">
	<div
		class="team-modal"
		role="dialog"
		aria-modal="true"
		aria-labelledby="team-modal-title">
		<div class="team-modal-header">
			<h3 id="team-modal-title">Elegi o crea tu equipo</h3>
			<button
				class="team-close-btn"
				id="team-close-btn"
				aria-label="Cerrar"
				>&times;</button
			>
		</div>
		<button
			class="team-action-btn"
			id="team-action-btn"
			disabled
			>Escribi un nombre</button
		>
		<div class="combobox">
			<input
				type="text"
				placeholder="Busca o escribi el nombre del equipo..."
				class="combobox-input"
				id="combobox-input"
				autocomplete="off"
				aria-label="Nombre del equipo"
			/>
			<ul
				class="combobox-list"
				id="combobox-list"
				role="listbox">
			</ul>
		</div>
		<p class="team-modal-hint">
			Usa las flechas para navegar, Enter para confirmar
		</p>
	</div>
</div>

<style>
	#team-modal {
		--tm-accent: var(--action-color, #40bf6a);
		--tm-accent-hover: var(--action-color-state, #17823b);
		--tm-bg: var(--background, #fff);
		--tm-bg-input: var(--neutral-background, #fafafa);
		--tm-border: var(--neutral-400, #e6e6e6);
		--tm-text: var(--font-color, #1a1a1a);
		--tm-text-muted: var(--neutral-700, #595959);
		--tm-radius: var(--radius-large, 6px);
		--tm-font: var(--font-family-default, 'Open Sans', sans-serif);
	}

	.team-modal-backdrop {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.45);
		backdrop-filter: blur(3px);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 9999;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.25s ease, visibility 0.25s ease;
	}
	.team-modal-backdrop.open {
		opacity: 1;
		visibility: visible;
	}

	.team-modal {
		font-family: var(--tm-font);
		background: var(--tm-bg);
		color: var(--tm-text);
		border: 3px solid var(--tm-accent);
		border-radius: var(--tm-radius);
		padding: 1.5rem;
		max-width: 380px;
		width: 90%;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
		transform: translateY(6px);
		transition: transform 0.2s ease;
	}
	.team-modal-backdrop.open .team-modal {
		transform: translateY(0);
	}

	.team-modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 0.75rem;
		border-bottom: 2px solid var(--tm-border);
	}
	.team-modal-header h3 {
		font-family: var(--tm-font);
		font-size: 1.1rem;
		font-weight: 700;
		margin: 0;
		color: var(--tm-text);
	}

	.team-close-btn {
		background: none;
		border: none;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
		color: var(--tm-text-muted);
		padding: 0.15rem 0.4rem;
		border-radius: var(--tm-radius);
		transition: color 0.15s ease, background-color 0.15s ease;
	}
	.team-close-btn:hover {
		color: var(--tm-text);
		background-color: var(--tm-border);
	}

	.team-action-btn {
		font-family: var(--tm-font);
		font-size: 1rem;
		font-weight: 700;
		width: 100%;
		padding: 0.75rem 1rem;
		border: 3px solid var(--tm-accent);
		border-radius: var(--tm-radius);
		background-color: var(--tm-accent);
		color: var(--neutral-900, #1a1a1a);
		cursor: pointer;
		text-align: center;
		transition: background-color 0.15s ease, border-color 0.15s ease;
		line-height: 1;
	}
	.team-action-btn:hover:not(:disabled) {
		background-color: var(--tm-accent-hover);
		border-color: var(--tm-accent-hover);
		color: var(--neutral-900, #1a1a1a);
	}
	.team-action-btn:disabled {
		opacity: 0.45;
		cursor: not-allowed;
	}

	.combobox {
		position: relative;
		display: flex;
		flex-direction: column;
	}

	.combobox-input {
		font-family: var(--tm-font);
		font-size: 0.95rem;
		width: 100%;
		padding: 0.65rem 0.85rem;
		background: var(--tm-bg-input);
		color: var(--tm-text);
		border: 2px solid var(--tm-border);
		border-radius: var(--tm-radius);
		outline: none;
		transition: border-color 0.15s ease, box-shadow 0.15s ease;
	}
	.combobox-input:focus {
		border-color: var(--tm-accent);
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--tm-accent) 25%, transparent);
	}
	.combobox-input::placeholder {
		color: var(--tm-text-muted);
	}

	.combobox-list {
		display: none;
		position: absolute;
		top: calc(100% + 3px);
		left: 0;
		right: 0;
		max-height: 170px;
		overflow-y: auto;
		background: var(--tm-bg);
		border: 2px solid var(--tm-accent);
		border-radius: var(--tm-radius);
		z-index: 10;
		list-style: none;
		padding: 0.25rem;
		margin: 0;
		box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1);
	}
	.combobox-list.open {
		display: block;
	}

	/* Estas clases (.combobox-option) se inyectan por JS, las estilizamos de forma global dentro del modal */
	:global(.combobox-option) {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.55rem 0.75rem;
		font-size: 0.9rem;
		font-family: var(--tm-font);
		color: var(--tm-text);
		cursor: pointer;
		border-radius: calc(var(--tm-radius) - 2px);
		transition: background-color 0.12s ease, color 0.12s ease;
	}
	:global(.combobox-option .team-icon) {
		flex-shrink: 0;
		opacity: 0.5;
		transition: opacity 0.12s ease;
	}
	:global(.combobox-option .team-icon svg) {
		display: block;
	}
	:global(.combobox-option:hover),
	:global(.combobox-option.active) {
		background-color: var(--tm-accent);
		color: var(--neutral-900, #1a1a1a);
	}
	:global(.combobox-option:hover .team-icon),
	:global(.combobox-option.active .team-icon) {
		opacity: 1;
	}

	.team-modal-hint {
		font-family: var(--tm-font);
		font-size: 0.75rem;
		color: var(--tm-text-muted);
		text-align: center;
		margin-top: -0.25rem;
	}

	@media (max-width: 400px) {
		.team-modal {
			padding: 1.1rem;
			gap: 0.75rem;
		}
	}
</style>
