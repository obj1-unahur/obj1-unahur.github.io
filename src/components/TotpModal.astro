---
// src/components/TotpModal.astro
---

<div
	id="totp-modal"
	class="modal-overlay hidden">
	<div class="modal-content">
		<h3>Código de Autorización</h3>
		<p>
			Ingresá el código temporal proyectado por el docente para crear tu
			repositorio.
		</p>

		<input
			type="text"
			id="totp-input"
			maxlength="6"
			placeholder="Ej: 123456"
			autocomplete="off"
		/>

		<div class="modal-actions">
			<button
				id="totp-cancel"
				class="btn-cancel"
				>Cancelar</button
			>
			<button
				id="totp-submit"
				class="btn-submit"
				>Verificar</button
			>
		</div>
	</div>
</div>

<style>
	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.6);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 9999;
		backdrop-filter: blur(4px); /* Le da ese toque moderno al fondo */
	}

	.hidden {
		display: none !important;
	}

	.modal-content {
		background: #ffffff;
		padding: 2rem;
		border-radius: 8px;
		max-width: 400px;
		width: 90%;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
		text-align: center;
		color: #333;
	}

	/* Modo oscuro por defecto si el SO lo pide */
	@media (prefers-color-scheme: dark) {
		.modal-content {
			background: #1f2937;
			color: #f3f4f6;
		}
	}

	.modal-content h3 {
		margin-top: 0;
		margin-bottom: 0.5rem;
	}

	.modal-content p {
		font-size: 0.9rem;
		margin-bottom: 1.5rem;
		opacity: 0.8;
	}

	#totp-input {
		width: 100%;
		box-sizing: border-box;
		padding: 0.75rem;
		margin-bottom: 1.5rem;
		font-size: 1.5rem;
		text-align: center;
		letter-spacing: 0.5rem;
		border: 2px solid #ccc;
		border-radius: 6px;
		outline: none;
		transition: border-color 0.2s;
	}

	#totp-input:focus {
		border-color: #3b82f6; /* Color de foco azul */
	}

	@media (prefers-color-scheme: dark) {
		#totp-input {
			background: #374151;
			border-color: #4b5563;
			color: white;
		}
	}

	.modal-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
	}

	.modal-actions button {
		padding: 0.6rem 1.2rem;
		border-radius: 6px;
		border: none;
		cursor: pointer;
		font-weight: 600;
		font-size: 1rem;
		transition: opacity 0.2s;
	}

	.modal-actions button:hover {
		opacity: 0.8;
	}

	.btn-cancel {
		background: #e5e7eb;
		color: #374151;
	}

	.btn-submit {
		background: #3b82f6;
		color: white;
	}
</style>
