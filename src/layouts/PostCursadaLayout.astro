---
import { Breadcrumbs } from 'accessible-astro-components'
import { BreadcrumbsItem } from 'accessible-astro-components'
import { PATH, PATH_CURSADA } from '@/paths.js'
import LayoutSemanas from './LayoutSemanas.astro'
import VideosDeSemana from '@components/VideosDeSemana.astro'
import ActividadesDeSemana from '@components/ActividadesDeSemana.astro'
import HorariosDeSemana from '@components/HorariosDeSemana.astro'
import CardSecciones from '@/components/CardSecciones.astro'
import TotpModal from '@components/TotpModal.astro'
import TeamModal from '@/components/TeamModal.astro'

const { frontmatter } = Astro.props

const { title, videos, horarios, ejercicios, atencion, importante } =
	frontmatter
---

<LayoutSemanas title={title}>
	<div class="container">
		<div class="mt-12">
			<Breadcrumbs>
				<BreadcrumbsItem
					href={PATH}
					label="Inicio"
				/>
				<BreadcrumbsItem
					href={PATH_CURSADA}
					label="Cursada"
				/>
				<BreadcrumbsItem
					currentPage={true}
					label={title}
				/>
			</Breadcrumbs>
		</div>
	</div>

	<div class="container">
		<div class="my-12">
			<h1 class="pb-3">{title}</h1>

			{
				atencion ? (
					<CardSecciones
						title="Atención"
						atencion>
						{atencion}
					</CardSecciones>
				) : null
			}

			{
				importante ? (
					<CardSecciones
						title="Importante"
						importante>
						{importante}
					</CardSecciones>
				) : null
			}

			<div class="pb-2">
				<slot />
			</div>

			{horarios ? <HorariosDeSemana horarios={horarios} /> : null}

			{
				videos && (
					<VideosDeSemana
						titulo="Videos"
						videos={videos}
					/>
				)
			}

			<ActividadesDeSemana ejercicios={ejercicios} />
		</div>
	</div>
	<TotpModal />
	<TeamModal />
</LayoutSemanas>

<script>
	//WORKER PROD
	const WORKER_URL = 'https://worker-objetos.objetos-unahur.workers.dev'
	//WORKER TEST
	//const WORKER_URL ='https://test-worker-objetos.objetos-unahur.workers.dev/'

	if (!window.__githubHandlerAttached) {
		window.__githubHandlerAttached = true

		const PROCESSING_TEXT = 'Procesando...'
		const SUCCESS_TEXT = '✓ ¡Listo! Abriendo...'
		const ERROR_TEXT = '✗ Error, intentá de nuevo'
		const ACCEPTED_TEXT = 'Aceptado. Ir al repo →'

		const getInput = () => document.querySelector('.github-user-input')
		const syncInput = () => {
			const input = getInput()
			const saved = localStorage.getItem('githubUser')
			if (input && saved && input.value !== saved) input.value = saved
		}

		// ---------- assignments ----------
		const ACCEPTED_KEY = 'acceptedAssignments'
		const assignments = {
			get: () => {
				try {
					return JSON.parse(localStorage.getItem(ACCEPTED_KEY)) || []
				} catch {
					return []
				}
			},
			mark: (prefix, type) => {
				const list = assignments.get()
				if (!list.some((a) => a.prefix === prefix && a.type === type)) {
					list.push({ prefix, type })
					localStorage.setItem(ACCEPTED_KEY, JSON.stringify(list))
				}
			},
			has: (prefix, type) =>
				assignments.get().some((a) => a.prefix === prefix && a.type === type),
		}

		// ---------- SVGs ----------
		const svg = (path, size = 24) =>
			`<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${path}</svg>`
		const CHECK_ICON = svg(
			`<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
			24
		)
		const TEAM_ICON = svg(
			`<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
			16
		)

		// ---------- botones aceptados ----------
		const updateAcceptedButtons = () => {
			document.querySelectorAll('.aceptar-invitacion').forEach((btn) => {
				const prefix = btn.getAttribute('data-prefix')
				const type = btn.getAttribute('data-type') ?? 'individual'
				if (assignments.has(prefix, type)) {
					btn.innerHTML = `<span style="vertical-align:middle;margin-right:4px">${CHECK_ICON}</span> ${ACCEPTED_TEXT}`
				}
			})
		}

		// ---------- eventos globales ----------
		const onLoad = (fn) => {
			document.addEventListener('DOMContentLoaded', fn)
			document.addEventListener('astro:page-load', fn)
			fn()
		}

		onLoad(updateAcceptedButtons)
		onLoad(syncInput)

		document.addEventListener('input', (e) => {
			if (e.target.classList.contains('github-user-input'))
				localStorage.setItem('githubUser', e.target.value.trim())
		})

		// --- FUNCIÓN GLOBAL PARA CERRAR EL MODAL TOTP ---
		const hideTotpModal = () => {
			document.getElementById('totp-modal')?.classList.add('hidden')
			document
				.getElementById('totp-modal-content')
				?.classList.remove('shake-anim')
		}

		// =========================================================================
		// 1. TOTP MODAL
		// =========================================================================
		const askTotpCode = (btn, errorMsg = null) => {
			if (btn.getAttribute('data-require-totp') !== 'true')
				return Promise.resolve(null)

			return new Promise((resolve) => {
				const modal = document.getElementById('totp-modal')
				const content = document.getElementById('totp-modal-content')
				const input = document.getElementById('totp-input')
				const errorBox = document.getElementById('totp-error-box')
				const errorTxt = document.getElementById('totp-error-text')
				const submitBtn = document.getElementById('totp-submit')
				const cancelBtn = document.getElementById('totp-cancel')
				const closeBtn = document.getElementById('totp-close')

				// Limpiamos y re-habilitamos el modal (por si viene de un reintento)
				input.value = ''
				input.disabled = false
				submitBtn.disabled = false
				cancelBtn.disabled = false
				submitBtn.textContent = 'Verificar'
				errorBox.classList.add('hidden')
				input.classList.remove('is-invalid')
				content.classList.remove('shake-anim')

				const showError = (msg) => {
					errorTxt.textContent = msg
					errorBox.classList.remove('hidden')
					input.classList.add('is-invalid')

					content.classList.remove('shake-anim')
					void content.offsetWidth
					content.classList.add('shake-anim')
				}

				if (errorMsg) showError(errorMsg)

				let resolved = false

				const cleanup = () => {
					if (resolved) return
					resolved = true
					// YA NO CERRAMOS EL MODAL ACÁ. Solo limpiamos los eventos.
					submitBtn.removeEventListener('click', intentarSubmit)
					cancelBtn.removeEventListener('click', handleCancel)
					closeBtn?.removeEventListener('click', handleCancel)
					input.removeEventListener('keydown', handleKeydown)
				}

				const intentarSubmit = () => {
					const val = input.value.trim()

					if (!/^\d{6}$/.test(val)) {
						showError('El código es incorrecto.')
						input.focus()
						return
					}

					// Estado visual de carga (el modal se queda abierto)
					input.disabled = true
					submitBtn.disabled = true
					cancelBtn.disabled = true
					submitBtn.textContent = 'Verificando...'

					cleanup()
					resolve(val) // Resolvemos la promesa pero el modal sigue visible
				}

				const handleCancel = () => {
					hideTotpModal() // Si el usuario cancela, sí lo cerramos explícitamente
					cleanup()
					resolve(null)
				}

				const handleKeydown = (e) => {
					if (e.key === 'Enter') intentarSubmit()
					if (e.key === 'Escape') handleCancel()
				}

				submitBtn.addEventListener('click', intentarSubmit)
				cancelBtn.addEventListener('click', handleCancel)
				closeBtn?.addEventListener('click', handleCancel)
				input.addEventListener('keydown', handleKeydown)

				modal.classList.remove('hidden')
				setTimeout(() => input.focus(), 50)
			})
		}

		// =========================================================================
		// 2. TEAM MODAL
		// =========================================================================
		const openTeamModal = (teams) => {
			return new Promise((resolve) => {
				const modal = document.getElementById('team-modal')
				const input = document.getElementById('combobox-input')
				const list = document.getElementById('combobox-list')
				const actionBtn = document.getElementById('team-action-btn')
				const closeBtn = document.getElementById('team-close-btn')

				input.value = ''
				list.innerHTML = ''
				actionBtn.disabled = true
				list.classList.remove('open')

				let activeIndex = -1
				let resolved = false

				const cleanup = () => {
					if (resolved) return
					resolved = true

					modal.classList.remove('open')

					input.oninput = null
					actionBtn.onclick = null
					closeBtn.onclick = null

					input.removeEventListener('keydown', handleKeydown)
				}

				const updateUI = (forceClose = false) => {
					const search = input.value.trim().toLowerCase()

					const suggestions = search
						? teams.filter((t) => t.teamName.toLowerCase().includes(search))
						: []

					if (activeIndex >= suggestions.length) activeIndex = -1

					list.innerHTML = ''

					suggestions.forEach((team, idx) => {
						const li = document.createElement('li')

						li.className = 'combobox-option'

						if (idx === activeIndex) li.classList.add('active')

						li.innerHTML = `
              <span class="team-icon">${TEAM_ICON}</span>
              <span>${team.teamName}</span>
            `

						li.addEventListener('mousedown', (e) => {
							e.preventDefault()

							input.value = team.teamName
							activeIndex = -1

							updateUI(true)
							input.focus()
						})

						list.appendChild(li)
					})

					list.classList.toggle(
						'open',
						suggestions.length > 0 && !!search && !forceClose
					)

					if (activeIndex >= 0) {
						list
							.querySelectorAll('.combobox-option')
							[activeIndex]?.scrollIntoView({
								block: 'nearest',
								behavior: 'smooth',
							})
					}

					const val = input.value.trim()

					const exists = teams.some(
						(t) => t.teamName.toLowerCase() === val.toLowerCase()
					)

					actionBtn.textContent = val
						? exists
							? 'Unirse al equipo'
							: `Crear "${val}"`
						: 'Escribí un nombre'

					actionBtn.disabled = !val
				}

				const handleKeydown = (e) => {
					const items = list.querySelectorAll('.combobox-option')

					if (e.key === 'ArrowDown') {
						e.preventDefault()

						if (items.length) {
							activeIndex = Math.min(activeIndex + 1, items.length - 1)
							updateUI()
						}
					} else if (e.key === 'ArrowUp') {
						e.preventDefault()

						if (items.length) {
							activeIndex = Math.max(activeIndex - 1, 0)
							updateUI()
						}
					} else if (e.key === 'Enter') {
						e.preventDefault()

						if (activeIndex >= 0 && activeIndex < items.length) {
							const teamName = list
								.querySelectorAll('.combobox-option')
								[activeIndex]?.querySelector('span:last-child')?.textContent

							if (teamName) {
								input.value = teamName
								activeIndex = -1

								updateUI(true)
								input.focus()
							}
						} else if (!actionBtn.disabled) {
							actionBtn.onclick()
						}
					} else if (e.key === 'Escape') {
						cleanup()
						resolve(null)
					}
				}

				actionBtn.onclick = () => {
					const val = input.value.trim()

					if (!val) return

					const exists = teams.some(
						(t) => t.teamName.toLowerCase() === val.toLowerCase()
					)

					cleanup()

					resolve({
						teamName: val,
						mode: exists ? 'join' : 'create',
					})
				}

				closeBtn.onclick = () => {
					cleanup()
					resolve(null)
				}

				input.oninput = () => {
					activeIndex = -1
					updateUI()
				}

				input.addEventListener('keydown', handleKeydown)

				modal.classList.add('open')

				setTimeout(() => input.focus(), 100)
			})
		}

		// =========================================================================
		// 3. FETCH CON REINTENTO TOTP
		// =========================================================================
		const isTotpError = (data) => {
			if (!data?.error) return false

			const err = String(data.error).toLowerCase()

			return (
				err.includes('totp') ||
				err.includes('inválido') ||
				err.includes('invalido') ||
				err.includes('incorrecto') ||
				err.includes('expired') ||
				err.includes('expirado')
			)
		}

		const fetchConReintento = async (btn, body) => {
			let codigoActual = body.totpCode

			while (true) {
				const res = await fetch(WORKER_URL, {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						...body,
						totpCode: codigoActual,
					}),
				})

				let data = null

				try {
					data = await res.json()
				} catch {
					data = null
				}

				// SUCCESS
				if (res.ok && !data?.error) {
					return data
				}

				// ERROR TOTP → El modal ya está abierto, solo actualizamos su UI pidiendo otro código
				if (isTotpError(data)) {
					const nuevoCodigo = await askTotpCode(
						btn,
						'Código incorrecto o expirado, intentá de nuevo.'
					)

					if (nuevoCodigo === null) {
						throw new Error('CANCELLED')
					}

					codigoActual = nuevoCodigo
					continue
				}

				// Cualquier otro error
				throw new Error(data?.error || 'Error al procesar')
			}
		}

		// =========================================================================
		// 4. LÓGICA PRINCIPAL
		// =========================================================================
		document.addEventListener('click', async (e) => {
			const btn = e.target.closest('.aceptar-invitacion')

			if (!btn) return

			e.preventDefault()

			const input = getInput()

			let usuario = input?.value?.trim() || localStorage.getItem('githubUser')

			if (!usuario) {
				alert('Ingresá tu usuario de GitHub')
				return
			}

			localStorage.setItem('githubUser', usuario)

			const totpCode = await askTotpCode(btn)

			if (
				totpCode === null &&
				btn.getAttribute('data-require-totp') === 'true'
			) {
				return
			}

			const originalHTML = btn.innerHTML

			btn.disabled = true
			btn.textContent = PROCESSING_TEXT

			const type = btn.getAttribute('data-type') ?? 'individual'
			const prefix = btn.getAttribute('data-prefix')
			const destOrg = btn.getAttribute('data-dest-org')

			const restoreButton = () => {
				btn.disabled = false
				btn.innerHTML = originalHTML
			}

			const handleError = (msg) => {
				btn.textContent = ERROR_TEXT

				setTimeout(restoreButton, 2000)

				console.error(msg)
			}

			try {
				// =========================================================
				// INDIVIDUAL
				// =========================================================
				if (type === 'individual') {
					const body = {
						type,
						username: usuario,
						totpCode,

						template: btn.getAttribute('data-template'),
						templateOrg: btn.getAttribute('data-template-org'),

						destOrg,
						prefix,

						isPrivate: btn.getAttribute('data-private') === 'true',
					}

					const data = await fetchConReintento(btn, body)

					hideTotpModal() // Si salió bien, ocultamos el modal

					assignments.mark(prefix, type)

					btn.textContent = SUCCESS_TEXT

					setTimeout(() => {
						window.open(`${data.repoUrl}/invitations`, '_blank')

						updateAcceptedButtons()

						btn.disabled = false
					}, 1500)
				}

				// =========================================================
				// GRUPAL
				// =========================================================
				else {
					const cacheKey = `teamCache_${destOrg}`

					const baseBody = {
						type,
						username: usuario,
						totpCode,
					}

					// VALIDAMOS TOTP PRIMERO
					await fetchConReintento(btn, {
						...baseBody,
						type: 'individual',
						template: '__totp_check__',
						templateOrg: '__totp_check__',
						destOrg: '__totp_check__',
						prefix: '__totp_check__',
					}).catch((err) => {
						if (err.message === 'CANCELLED') throw err
					})

					hideTotpModal() // Cerramos el modal de TOTP para darle paso al de Equipos

					let teamName
					let mode

					if (e.shiftKey) {
						localStorage.removeItem(cacheKey)
					}

					const cached = localStorage.getItem(cacheKey)

					if (cached) {
						;({ teamName, mode } = JSON.parse(cached))
					} else {
						const listRes = await fetch(WORKER_URL, {
							method: 'POST',

							headers: {
								'Content-Type': 'application/json',
							},

							body: JSON.stringify({
								...baseBody,
								type: 'group',
								action: 'list-teams',
								destOrg,
							}),
						})

						const listData = await listRes.json()

						if (!listRes.ok || listData.error) {
							throw new Error(listData.error || 'Error listando equipos')
						}

						const decision = await openTeamModal(listData.teams || [])

						if (!decision) {
							restoreButton()
							return
						}

						;({ teamName, mode } = decision)

						localStorage.setItem(cacheKey, JSON.stringify({ teamName, mode }))
					}

					const body = {
						...baseBody,

						type: 'group',
						action: 'accept',

						prefix,
						destOrg,

						templateOrg: btn.getAttribute('data-template-org'),
						templateRepo: btn.getAttribute('data-template'),

						isPrivate: btn.getAttribute('data-private') === 'true',

						mode,
						teamName,
					}

					const acceptData = await fetchConReintento(btn, body)

					hideTotpModal() // Por seguridad, si ocurrió un reintento tardío

					assignments.mark(prefix, type)

					btn.textContent = SUCCESS_TEXT

					setTimeout(() => {
						window.open(
							acceptData.needsInvitation
								? `${acceptData.repoUrl}/invitations`
								: acceptData.repoUrl,
							'_blank'
						)

						updateAcceptedButtons()

						btn.disabled = false
					}, 1500)
				}
			} catch (err) {
				hideTotpModal() // Nos aseguramos de limpiar el modal si explota por otra cosa

				if (err.message !== 'CANCELLED') {
					handleError(err)
				} else {
					restoreButton()
				}
			}
		})
	}
</script>
