---
import { Breadcrumbs } from 'accessible-astro-components'
import { BreadcrumbsItem } from 'accessible-astro-components'
import { PATH, PATH_CURSADA } from '@/paths.js'
import LayoutSemanas from './LayoutSemanas.astro'
import VideosDeSemana from '@components/VideosDeSemana.astro'
import ActividadesDeSemana from '@components/ActividadesDeSemana.astro'
import HorariosDeSemana from '@components/HorariosDeSemana.astro'
import CardSecciones from '@/components/CardSecciones.astro'

const { frontmatter } = Astro.props

const { title, videos, horarios, ejercicios, atencion, importante } =
	frontmatter
---

<LayoutSemanas title={title}>
	<div class="container">
		<div class="mt-12">
			<Breadcrumbs>
				<BreadcrumbsItem
					href={PATH}
					label="Inicio"
				/>
				<BreadcrumbsItem
					href={PATH_CURSADA}
					label="Cursada"
				/>
				<BreadcrumbsItem
					currentPage={true}
					label={title}
				/>
			</Breadcrumbs>
		</div>
	</div>

	<div class="container">
		<div class="my-12">
			<h1 class="pb-3">{title}</h1>

			{
				atencion ? (
					<CardSecciones
						title="Atención"
						atencion>
						{atencion}
					</CardSecciones>
				) : null
			}

			{
				importante ? (
					<CardSecciones
						title="Importante"
						importante>
						{importante}
					</CardSecciones>
				) : null
			}

			<div class="pb-2">
				<slot />
			</div>

			{horarios ? <HorariosDeSemana horarios={horarios} /> : null}

			{
				videos && (
					<VideosDeSemana
						titulo="Videos"
						videos={videos}
					/>
				)
			}

			<ActividadesDeSemana ejercicios={ejercicios} />
		</div>
	</div>
</LayoutSemanas>

<script>
	if (!window.__githubHandlerAttached) {
		window.__githubHandlerAttached = true

		const getInput = () => document.querySelector('.github-user-input')

		const syncInput = () => {
			const input = getInput()
			const saved = localStorage.getItem('githubUser')
			if (input && saved && input.value !== saved) {
				input.value = saved
			}
		}

		// 1) Carga inicial (página completa)
		document.addEventListener('DOMContentLoaded', syncInput)

		// 2) Navegación cliente de Astro (View Transitions)
		// (se dispara cuando cambiás de semana sin recargar)
		document.addEventListener('astro:page-load', syncInput)

		// 3) Por si el input se monta tarde
		const observer = new MutationObserver(syncInput)
		observer.observe(document.body, { childList: true, subtree: true })

		// 4) Guardado en vivo
		document.addEventListener('input', (e) => {
			if (e.target.classList.contains('github-user-input')) {
				localStorage.setItem('githubUser', e.target.value.trim())
			}
		})

		// 5) Click en botones
		document.addEventListener('click', async (e) => {
			const btn = e.target.closest('.aceptar-invitacion');
			if (!btn) return;
			e.preventDefault();

			const input = getInput();
			let usuario = input?.value?.trim() || localStorage.getItem('githubUser');
			if (!usuario) {
				alert('Ingresá tu usuario de GitHub en la sección de ejercicios');
				return;
			}
			localStorage.setItem('githubUser', usuario);

			btn.disabled = true;
			btn.textContent = 'Procesando...';

			const type = btn.getAttribute('data-type') ?? 'individual';

			// ===================== INDIVIDUAL =====================
			if (type === 'individual') {
				try {
					const res = await fetch('https://worker-objetos.objetos-unahur.workers.dev', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							type: 'individual',
							template: btn.getAttribute('data-template'),
							templateOrg: btn.getAttribute('data-template-org'),
							destOrg: btn.getAttribute('data-dest-org'),
							prefix: btn.getAttribute('data-prefix'),
							isPrivate: btn.getAttribute('data-private') === 'true',
							username: usuario,
						}),
					});

					const data = await res.json();

					if (data.status === 'ok') {
						btn.textContent = '✓ ¡Listo! Abriendo repo...';
						setTimeout(() => {
							window.open(`${data.repoUrl}/invitations`, '_blank');
							btn.disabled = false;
							btn.textContent = 'Aceptar la asignación';
						}, 1500);
					} else {
						btn.textContent = '✗ Error, intentá de nuevo';
						btn.disabled = false;
						console.error(data);
					}
				} catch (err) {
					btn.textContent = '✗ Error de conexión';
					btn.disabled = false;
					console.error(err);
				}
				return;
			}

			// ===================== GRUPAL =====================
			const destOrg = btn.getAttribute('data-dest-org');

			try {
				// 1. Obtener lista de equipos de la organización
				btn.textContent = 'Buscando equipos...';
				const listRes = await fetch('https://worker-objetos.objetos-unahur.workers.dev', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						type: 'group',
						action: 'list-teams',
						destOrg,
					}),
				});
				const { teams } = await listRes.json();

				// 2. Mostrar opciones al alumno
				let teamName;
				let mode;

				if (teams.length > 0) {
					const teamList = teams.map((t, i) => `${i + 1}. ${t.teamName}`).join('\n');
					const choice = prompt(
						`Equipos disponibles para esta tarea:\n${teamList}\n\nElegí el número para unirte, o escribí un nombre nuevo para crear uno:`
					);
					if (!choice) throw new Error('Cancelado');

					const num = parseInt(choice, 10);
					if (num > 0 && num <= teams.length) {
						teamName = teams[num - 1].teamName;
						mode = 'join';
					} else {
						teamName = choice.trim();
						if (!teamName) throw new Error('Nombre inválido');
						mode = 'create';
					}
				} else {
					teamName = prompt('No hay equipos creados todavía.\nEscribí el nombre de tu nuevo equipo:');
					if (!teamName || !teamName.trim()) throw new Error('Cancelado');
					teamName = teamName.trim();
					mode = 'create';
				}

				// 3. Aceptar la asignación grupal (join o create)
				btn.textContent = mode === 'create' ? 'Creando equipo...' : 'Uniéndote al equipo...';
				const acceptRes = await fetch('https://worker-objetos.objetos-unahur.workers.dev', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						type: 'group',
						action: 'accept',
						username: usuario,
						prefix: btn.getAttribute('data-prefix'),
						destOrg,
						templateOrg: btn.getAttribute('data-template-org'),
						templateRepo: btn.getAttribute('data-template'),
						isPrivate: btn.getAttribute('data-private') === 'true',
						mode,
						teamName,
					}),
				});

				const acceptData = await acceptRes.json();

				if (acceptData.success) {
					btn.textContent = '✓ ¡Listo! Abriendo repo...';
					setTimeout(() => {
						window.open(acceptData.repoUrl, '_blank'); // directo al repo
						btn.disabled = false;
						btn.textContent = 'Aceptar la asignación';
					}, 1500);
				} else {
					btn.textContent = '✗ Error, intentá de nuevo';
					btn.disabled = false;
					console.error(acceptData);
				}
			} catch (err) {
				btn.textContent = '✗ Error de conexión';
				btn.disabled = false;
				console.error(err);
			}
		});

		// Ejecutar una vez por si ya está todo en DOM
		syncInput()
	}
</script>
