---
import { Breadcrumbs } from 'accessible-astro-components'
import { BreadcrumbsItem } from 'accessible-astro-components'
import { PATH, PATH_CURSADA } from '@/paths.js'
import LayoutSemanas from './LayoutSemanas.astro'
import VideosDeSemana from '@components/VideosDeSemana.astro'
import ActividadesDeSemana from '@components/ActividadesDeSemana.astro'
import HorariosDeSemana from '@components/HorariosDeSemana.astro'
import CardSecciones from '@/components/CardSecciones.astro'

const { frontmatter } = Astro.props

const { title, videos, horarios, ejercicios, atencion, importante } =
	frontmatter
---

<LayoutSemanas title={title}>
	<div class="container">
		<div class="mt-12">
			<Breadcrumbs>
				<BreadcrumbsItem
					href={PATH}
					label="Inicio"
				/>
				<BreadcrumbsItem
					href={PATH_CURSADA}
					label="Cursada"
				/>
				<BreadcrumbsItem
					currentPage={true}
					label={title}
				/>
			</Breadcrumbs>
		</div>
	</div>

	<div class="container">
		<div class="my-12">
			<h1 class="pb-3">{title}</h1>

			{
				atencion ? (
					<CardSecciones
						title="Atención"
						atencion>
						{atencion}
					</CardSecciones>
				) : null
			}

			{
				importante ? (
					<CardSecciones
						title="Importante"
						importante>
						{importante}
					</CardSecciones>
				) : null
			}

			<div class="pb-2">
				<slot />
			</div>

			{horarios ? <HorariosDeSemana horarios={horarios} /> : null}

			{
				videos && (
					<VideosDeSemana
						titulo="Videos"
						videos={videos}
					/>
				)
			}

			<ActividadesDeSemana ejercicios={ejercicios} />
		</div>
	</div>
</LayoutSemanas>

<script>
	//WORKER PROD
	const WORKER_URL = 'https://worker-objetos.objetos-unahur.workers.dev'
	//WORKER TEST
	//const WORKER_URL ='https://test-worker-objetos.objetos-unahur.workers.dev/'
	if (!window.__githubHandlerAttached) {
		window.__githubHandlerAttached = true

		// ---------- textos ----------
		const PROCESSING_TEXT = 'Procesando...'
		const SUCCESS_TEXT = '✓ ¡Listo! Abriendo...'
		const ERROR_TEXT = '✗ Error, intentá de nuevo'
		const ACCEPTED_TEXT = 'Aceptado. Ir al repo →'

		// ---------- utilidades ----------
		const getInput = () => document.querySelector('.github-user-input')

		const syncInput = () => {
			const input = getInput()
			const saved = localStorage.getItem('githubUser')
			if (input && saved && input.value !== saved) {
				input.value = saved
			}
		}

		// ---------- manejo de ejercicios aceptados ----------
		const ACCEPTED_KEY = 'acceptedAssignments'
		const getAcceptedAssignments = () => {
			try {
				return JSON.parse(localStorage.getItem(ACCEPTED_KEY)) || []
			} catch {
				return []
			}
		}
		const markAssignmentAccepted = (prefix, type) => {
			const accepted = getAcceptedAssignments()
			if (!accepted.some((a) => a.prefix === prefix && a.type === type)) {
				accepted.push({ prefix, type })
				localStorage.setItem(ACCEPTED_KEY, JSON.stringify(accepted))
			}
		}
		const isAssignmentAccepted = (prefix, type) =>
			getAcceptedAssignments().some(
				(a) => a.prefix === prefix && a.type === type
			)

		const CHECK_ICON_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`

		const TEAM_ICON_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`

		const updateAcceptedButtons = () => {
			document.querySelectorAll('.aceptar-invitacion').forEach((btn) => {
				const prefix = btn.getAttribute('data-prefix')
				const type = btn.getAttribute('data-type') ?? 'individual'
				if (isAssignmentAccepted(prefix, type)) {
					btn.innerHTML = `${CHECK_ICON_SVG} ${ACCEPTED_TEXT}`
				}
			})
		}

		document.addEventListener('DOMContentLoaded', updateAcceptedButtons)
		document.addEventListener('astro:page-load', updateAcceptedButtons)
		updateAcceptedButtons()

		// ---------- sincronización del input ----------
		document.addEventListener('DOMContentLoaded', syncInput)
		document.addEventListener('astro:page-load', syncInput)
		syncInput()

		document.addEventListener('input', (e) => {
			if (e.target.classList.contains('github-user-input')) {
				localStorage.setItem('githubUser', e.target.value.trim())
			}
		})

		// ---------- TOTP: pedir código si el botón lo requiere ----------

		const askTotpCode = (btn) => {
			const requireTotp = btn.getAttribute('data-require-totp') === 'true'
			if (!requireTotp) return null

			const code = prompt(
				'🔐 Ingresá el código de 6 dígitos que muestra el profesor:'
			)
			if (!code) return null // usuario canceló

			return code.trim()
		}

		// ---------- Modal para equipos ----------
		const createTeamModal = () => {
			// ... (el código del modal se mantiene igual, no lo modifico)
			// Por brevedad no lo copio entero, pero lo dejas igual
		}

		const openTeamModal = (teams) => {
			// ... (sin cambios)
		}

		// ---------- click en botón aceptar asignación ----------
		document.addEventListener('click', async (e) => {
			const btn = e.target.closest('.aceptar-invitacion')
			if (!btn) return
			e.preventDefault()

			const input = getInput()
			let usuario = input?.value?.trim() || localStorage.getItem('githubUser')
			if (!usuario) {
				alert('Ingresa tu usuario de GitHub en la sección de ejercicios')
				return
			}
			localStorage.setItem('githubUser', usuario)

			// Pedir código TOTP si es necesario
			const totpCode = askTotpCode(btn)
			if (
				totpCode === null &&
				btn.getAttribute('data-require-totp') === 'true'
			) {
				// Usuario canceló, no hacemos nada
				return
			}

			const originalHTML = btn.innerHTML
			btn.disabled = true
			btn.textContent = PROCESSING_TEXT

			const type = btn.getAttribute('data-type') ?? 'individual'
			const prefix = btn.getAttribute('data-prefix')

			const restoreButton = (targetBtn) => {
				targetBtn.disabled = false
				targetBtn.innerHTML = originalHTML
			}

			// Helper para construir el body base con TOTP
			const buildBaseBody = () => {
				const body = {
					type,
					username: usuario,
				}
				if (totpCode !== null && totpCode !== false) {
					body.totpCode = totpCode
				}
				const totpSecret = btn.getAttribute('data-totp-secret')
				if (totpSecret) body.totpSecret = totpSecret
				return body
			}

			// INDIVIDUAL
			if (type === 'individual') {
				try {
					const body = {
						...buildBaseBody(),
						template: btn.getAttribute('data-template'),
						templateOrg: btn.getAttribute('data-template-org'),
						destOrg: btn.getAttribute('data-dest-org'),
						prefix,
						isPrivate: btn.getAttribute('data-private') === 'true',
					}

					const res = await fetch(WORKER_URL, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(body),
					})
					const data = await res.json()
					if (data.status === 'ok') {
						markAssignmentAccepted(prefix, type)
						btn.textContent = SUCCESS_TEXT
						setTimeout(() => {
							window.open(`${data.repoUrl}/invitations`, '_blank')
							updateAcceptedButtons()
							btn.disabled = false
						}, 1500)
					} else {
						if (data.error === 'Código TOTP inválido') {
							alert(
								'❌ El código ingresado es incorrecto. Verificá el código en la pantalla del profesor.'
							)
						}
						throw new Error(data.error || 'Error al procesar')
					}
				} catch (err) {
					btn.textContent = ERROR_TEXT
					btn.disabled = false
					console.error(err)
					setTimeout(() => {
						btn.innerHTML = originalHTML
					}, 2000)
				}
				return
			}

			// GRUPAL
			const destOrg = btn.getAttribute('data-dest-org')
			if (!destOrg || destOrg === 'undefined') {
				alert('Error: falta la organizacion de destino en el boton.')
				restoreButton(btn)
				return
			}
			const cacheKey = `teamCache_${destOrg}`

			try {
				let teamName, mode

				if (e.shiftKey) {
					localStorage.removeItem(cacheKey)
				}

				const cachedTeam = localStorage.getItem(cacheKey)

				if (cachedTeam) {
					const parsed = JSON.parse(cachedTeam)
					teamName = parsed.teamName
					mode = parsed.mode
				} else {
					btn.textContent = 'Buscando equipos...'

					let teams = []
					try {
						const listRes = await fetch(WORKER_URL, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								type: 'group',
								action: 'list-teams',
								destOrg,
							}),
						})
						const listData = await listRes.json()
						if (listData.error) throw new Error(listData.error)
						teams = listData.teams || []
					} catch (fetchErr) {
						console.error('Error al buscar equipos:', fetchErr)
						btn.textContent = ERROR_TEXT
						setTimeout(() => {
							restoreButton(btn)
						}, 2000)
						return
					}

					let decision
					try {
						decision = await openTeamModal(teams)
					} catch (cancelErr) {
						restoreButton(btn)
						return
					}

					teamName = decision.teamName
					mode = decision.mode
					localStorage.setItem(cacheKey, JSON.stringify({ teamName, mode }))
				}

				const activeBtn =
					document.querySelector(
						`.aceptar-invitacion[data-prefix="${prefix}"]`
					) || btn
				activeBtn.disabled = true
				activeBtn.textContent = PROCESSING_TEXT

				const body = {
					...buildBaseBody(),
					type: 'group',
					action: 'accept',
					prefix,
					destOrg,
					templateOrg: btn.getAttribute('data-template-org'),
					templateRepo: btn.getAttribute('data-template'),
					isPrivate: btn.getAttribute('data-private') === 'true',
					mode,
					teamName,
				}

				const acceptRes = await fetch(WORKER_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(body),
				})
				const acceptData = await acceptRes.json()

				if (acceptData.success) {
					markAssignmentAccepted(prefix, type)
					activeBtn.textContent = SUCCESS_TEXT
					setTimeout(() => {
						const url = acceptData.needsInvitation
							? `${acceptData.repoUrl}/invitations`
							: acceptData.repoUrl
						window.open(url, '_blank')
						updateAcceptedButtons()
						activeBtn.disabled = false
					}, 1500)
				} else {
					if (acceptData.error === 'Código TOTP inválido') {
						alert(
							'❌ El código ingresado es incorrecto. Verificá el código en la pantalla del profesor.'
						)
					} else if (acceptData.error?.includes('no existe')) {
						localStorage.removeItem(cacheKey)
					}
					throw new Error(acceptData.error || 'Error al procesar')
				}
			} catch (err) {
				const currentBtn =
					document.querySelector(
						`.aceptar-invitacion[data-prefix="${prefix}"]`
					) || btn
				currentBtn.textContent = ERROR_TEXT
				currentBtn.disabled = false
				console.error(err)
				setTimeout(() => {
					currentBtn.innerHTML = originalHTML
				}, 2000)
			}
		})
	}
</script>
