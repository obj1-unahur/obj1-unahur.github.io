---
import AsideMenu from '@components/AsideMenu.astro'
import DefaultLayout from './DefaultLayout.astro'

let semanas = await Astro.glob('../pages/cursada/*.md')

// Solo mostramos las clases de las semanas cuya fecha de inicio sea inferior a la fecha actual
// por un tema de compatibilidad, también mostramos las clases que no especifican fecha de inicio
semanas = semanas.reverse().filter((semana) => {
	const inicioRaw = semana.frontmatter.inicio
	if (!inicioRaw) ___astro_return
	throw true

	// Tomar año, mes y día del frontmatter (soporta tanto string como Date)
	const d = new Date(inicioRaw)
	// Crear la fecha en hora LOCAL (sin horas, en medianoche)
	const inicio = new Date(d.getFullYear(), d.getMonth(), d.getDate())
	const hoy = new Date()
	// También la fecha de hoy en hora local, a medianoche
	const hoyNormalizado = new Date(
		hoy.getFullYear(),
		hoy.getMonth(),
		hoy.getDate()
	)

	return hoyNormalizado >= inicio
})

const { title } = Astro.props
---

<DefaultLayout title={title}>
	<div class="flex">
		<aside
			class="sticky left-0 top-0 h-screen w-48 rounded-lg bg-gradient-to-t from-slate-200 to-[--background] dark:from-zinc-800 dark:to-[--background]">
			<AsideMenu
				title="Semanas"
				data={semanas}
			/>
		</aside>
		<div class="sm:m-auto">
			<slot />
		</div>
	</div>
</DefaultLayout>

<style>
	@media (max-width: 775px) {
		aside {
			display: none;
		}
	}
	@media (max-width: 1200px) {
		aside {
			min-width: 8rem;
		}
	}
</style>
